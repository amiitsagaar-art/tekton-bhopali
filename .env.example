# ============================================================
# TEKTON BHOPAL MARKETPLACE - Environment Variables Template
# ============================================================
# Copy this file as .env and fill in your actual values.
# NEVER commit your actual .env file to GitHub!

# -------------------------------------------------------
# 1. POSTGRESQL DATABASE (Use Neon.tech free cloud DB)
#    Get from: https://neon.tech → New Project → Connection String
# -------------------------------------------------------
DATABASE_URL="postgresql://username:password@ep-xxxx.us-east-1.aws.neon.tech/tekton_db?sslmode=require"

# -------------------------------------------------------
# 2. GOOGLE SHEETS INTEGRATION
#    Get from: Google Cloud Console → Service Accounts
# -------------------------------------------------------

# Your Google Spreadsheet ID (from the URL: /spreadsheets/d/THIS_PART/edit)
GOOGLE_SPREADSHEET_ID="your-spreadsheet-id-here"

# Service Account Email (from Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_EMAIL="tekton-sheets@your-project.iam.gserviceaccount.com"

# Service Account Private Key (from downloaded JSON key file)
# IMPORTANT: Keep the quotes and replace \n with actual newlines on Vercel
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour key here\n-----END PRIVATE KEY-----\n"

# Google Apps Script Webhook URL (for quick appends)
GOOGLE_SHEETS_WEBHOOK_URL="https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec"
